# Copy to `.env` and fill in real values (never commit `.env`).

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_OR_PUBLISHABLE_KEY

# Insea workflow: POST multipart form field `image` (file) + Bearer (same as Pokemon PWA)
VITE_AI_API_URL=
VITE_AI_API_KEY=

# --- Google OAuth: fix "redirect_uri_mismatch" ---
#
# Google Cloud Console → APIs & Credentials → OAuth 2.0 Client IDs → your WEB client
# → "Authorized redirect URIs" MUST include EXACTLY one line (no localhost here):
#
#   https://YOUR_PROJECT_REF.supabase.co/auth/v1/callback
#
# Copy the exact "Callback URL" from:
#   Supabase Dashboard → Authentication → Providers → Google
#
# Your app URL (e.g. http://localhost:5173/) belongs in Supabase only:
#   Authentication → URL Configuration → Redirect URLs
# NOT in Google's Authorized redirect URIs (unless you use a rare custom flow).
